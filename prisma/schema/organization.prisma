

model Organization {
    id          String       @id @default(uuid())
    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt
    name        String
    description String?
    users       User[]
    permissions Permission[]
    invitations Invitation[]
    todolists   Todolist[]
    todos       Todo[]
    todoPlans   Json?

    street     String
    city       String
    state      String
    postalCode String
    country    String

    tenantId String
    tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
